#!/bin/sh
# Regenerate the VJ work list from vj/works/ and stage it, so works-list.js
# always matches the directory without manual edits to WORK_OPTIONS.
# Enable once per clone with:  git config core.hooksPath .githooks

if command -v node >/dev/null 2>&1; then
  node vj/build-works.js || {
    echo "pre-commit: vj/build-works.js failed; aborting commit." >&2
    exit 1
  }
  git add vj/works/works-list.js
else
  echo "pre-commit: node not found, skipping vj/build-works.js" >&2
fi
